ANTHROPIC_API_KEY=your-api-key
VOYAGE_API_KEY=your-voyage-key

# ── Google Workspace integration (secretaryAgent) ────────────────────────────
# OAuth 2.0 refresh token for eog@ernestofgaia.xyz.
# Real values live on the VPS in /docker/ernestofgaia-mastra/.env — never commit.
#
# Setup:
#   1. GCP Console → APIs & Services → Credentials
#      Create OAuth client ID (Desktop app, name: ernestofgaia-secretary)
#   2. Run once locally to get the refresh token:
#      Windows PowerShell:
#        $env:GOOGLE_OAUTH_CLIENT_ID="YOUR_ID"
#        $env:GOOGLE_OAUTH_CLIENT_SECRET="YOUR_SECRET"
#        node src/scripts/get-google-token.mjs
#   3. Approve as eog@ernestofgaia.xyz in the browser that opens
#   4. Copy the three printed env vars to the VPS .env
#
# Rotation: OAuth refresh tokens for Internal Workspace apps don't expire
# unless revoked. If revoked, re-run get-google-token.mjs and restart
# the Mastra container.

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_TIMEZONE=America/Los_Angeles

# ── OCHI lead-intake route (deterministic, no LLM) ───────────────────────────
# Shared secret guarding POST /ochi-booking (Mastra) and its public proxy at
# https://ernestofgaia.xyz/api/ochi-booking. The OCHI app (separate MCOS-shell
# deploy) must send the SAME value in the x-ochi-secret header. If unset, the
# route fails closed (503). Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OCHI_BOOKING_SECRET=
